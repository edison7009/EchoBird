.whichclaw.pid
.electron-cache

# One-off / scratch files (do not commit)
tmp/
.agent/
# scripts/ is mostly scratch, but a few entries are real CI artifacts.
# Ignore everything by default and whitelist the keepers explicitly.
scripts/*
!scripts/build_en_pulse.py

# llama-server binaries (downloaded during CI build)
electron/tools/llama-server/bin/

# Antigravity local cache
.gemini/

# Rust / Tauri build artifacts
target/
src-tauri/target/
src-tauri/gen/

# Local Cargo config (contains machine-specific paths)
src-tauri/.cargo/config.toml

# Plugin build artifacts
plugins/*/target/
plugins/*/bridge/target/
tools/*/target/
roles/en/
roles/zh-Hans/

# Android signing keystore (NEVER commit — store in GitHub Secrets)
*.keystore
*-keystore-b64.txt
Echobird-MotherAgent/
references/
