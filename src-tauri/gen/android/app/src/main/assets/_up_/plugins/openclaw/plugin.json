{
    "id": "openclaw",
    "name": "OpenClaw",
    "protocol": "stdio-json",
    "bridge": {
        "linux": "bridge-linux",
        "darwin": "bridge-darwin",
        "win32": "bridge-win.exe"
    },
    "cli": {
        "command": "openclaw",
        "detectCommand": "openclaw --version",
        "args": [
            "agent",
            "--json",
            "--agent",
            "main",
            "--message"
        ],
        "resumeArgs": [
            "agent",
            "--json",
            "--agent",
            "main",
            "--session-id",
            "{sessionId}",
            "--message"
        ],
        "sessionArg": "--session-id",
        "sessionMode": "always",
        "modelArg": null,
        "systemPromptArg": null
    }
}