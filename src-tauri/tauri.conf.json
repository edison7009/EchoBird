{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Echobird",
  "version": "2.4.2",
  "identifier": "com.echobird.ai",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npx vite",
    "beforeBuildCommand": "npx vite build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Echobird",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Echobird Team",
    "copyright": "(c) 2025 Echobird Team",
    "shortDescription": "The Nexus for Models, Agents & Vibe Coding",
    "longDescription": "Echobird - The Nexus for Models, Agents & Vibe Coding. One hub to manage AI models, coding tools, and intelligent agents.",
    "homepage": "https://github.com/edison7009/Echobird",
    "category": "DeveloperTool",
    "resources": [
      "../tools/",
      "../plugins/"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "startMenuFolder": "Echobird"
      }
    }
  }
}