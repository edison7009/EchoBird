{
    "name": "QwenCode",
    "names": {
        "zh-CN": "通义灵码 CLI"
    },
    "category": "CLI Code",
    "apiProtocol": [
        "openai",
        "anthropic"
    ],
    "docs": "https://qwenlm.github.io/qwen-code-docs/en/users/overview",
    "website": "https://github.com/QwenLM/qwen-code",
    "command": "qwen",
    "startCommand": "qwen",
    "configDir": "~/.qwen",
    "configFile": "~/.qwen/settings.json",
    "requireConfigFile": false,
    "detectByConfigDir": false,
    "paths": {
        "win32": [
            "%APPDATA%/npm/qwen.cmd",
            "%USERPROFILE%/.local/bin/qwen.exe",
            "%USERPROFILE%/.bun/bin/qwen.exe"
        ],
        "darwin": [
            "/usr/local/bin/qwen",
            "/opt/homebrew/bin/qwen"
        ],
        "linux": [
            "/usr/local/bin/qwen",
            "/usr/bin/qwen",
            "~/.local/bin/qwen"
        ]
    }
}