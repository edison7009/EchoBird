{
    "name": "QClaw",
    "category": "AgentOS",
    "apiProtocol": [
        "openai",
        "anthropic"
    ],
    "docs": "https://qclaw.ai",
    "command": "qclaw",
    "startCommand": "qclaw gateway --allow-unconfigured",
    "configDir": "~/.qclaw",
    "configFile": "~/.qclaw/openclaw.json",
    "requireConfigFile": false,
    "detectByConfigDir": true,
    "paths": {
        "win32": [
            "E:/QClaw/QClaw.exe",
            "%ProgramFiles%/QClaw/QClaw.exe",
            "%LOCALAPPDATA%/Programs/QClaw/QClaw.exe"
        ],
        "darwin": [
            "/Applications/QClaw.app/Contents/MacOS/QClaw"
        ],
        "linux": [
            "/usr/local/bin/qclaw",
            "/usr/bin/qclaw"
        ]
    }
}
