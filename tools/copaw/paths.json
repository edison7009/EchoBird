{
    "name": "CoPaw",
    "category": "AgentOS",
    "apiProtocol": [
        "openai",
        "anthropic"
    ],
    "docs": "https://github.com/agentscope-ai/CoPaw",
    "website": "https://copaw.agentscope.io",
    "configDir": "~/.copaw",
    "requireConfigFile": false,
    "detectByConfigDir": true,
    "paths": {
        "win32": [
            "%LOCALAPPDATA%\\CoPaw\\CoPaw Desktop.vbs",
            "%LOCALAPPDATA%\\CoPaw\\Scripts\\copaw.exe"
        ],
        "darwin": [
            "/Applications/CoPaw.app/Contents/MacOS/CoPaw",
            "~/.local/bin/copaw"
        ],
        "linux": [
            "~/.local/bin/copaw",
            "/usr/local/bin/copaw"
        ]
    }
}