{
    "name": "NanoClaw",
    "category": "AgentOS",
    "apiProtocol": [
        "anthropic"
    ],
    "docs": "https://github.com/qwibitai/nanoclaw",
    "website": "https://nanoclaw.dev/",
    "envVar": "NANOCLAW_PATH",
    "detectByConfigDir": true,
    "configDir": "~/NanoClaw",
    "requireConfigFile": false,
    "paths": {
        "win32": [],
        "darwin": [
            "~/NanoClaw/src/index.ts",
            "~/nanoclaw/src/index.ts"
        ],
        "linux": [
            "~/NanoClaw/src/index.ts",
            "~/nanoclaw/src/index.ts"
        ]
    },
    "skillsPath": {
        "darwin": [
            "~/NanoClaw/.claude/skills",
            "~/nanoclaw/.claude/skills"
        ],
        "linux": [
            "~/NanoClaw/.claude/skills",
            "~/nanoclaw/.claude/skills"
        ]
    }
}