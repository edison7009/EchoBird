{
    "id": "zeroclaw",
    "name": "ZeroClaw",
    "protocol": "cli-oneshot",
    "cli": {
        "command": "zeroclaw",
        "detectCommand": "zeroclaw --version",
        "args": ["agent", "--json", "--message"],
        "resumeArgs": ["agent", "--json", "--session-id", "{sessionId}", "--message"],
        "sessionArg": "--session-id",
        "sessionMode": "always",
        "systemPromptArg": "--system-prompt",
        "systemPromptWhen": "new-session"
    }
}
